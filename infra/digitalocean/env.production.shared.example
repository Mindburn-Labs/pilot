# DigitalOcean production shared environment.
# Copy to .env.production.shared. This file is used by Docker Compose interpolation
# and may be loaded by multiple services. Do not put provider API keys here.

DOMAIN=pilot.mindburn.run
TLS_EMAIL=ops@mindburn.org
APP_URL=https://pilot.mindburn.run
ALLOWED_ORIGINS=https://pilot.mindburn.run

POSTGRES_DB=pilot
HELM_POSTGRES_DB=helm_governance
POSTGRES_USER=helm
POSTGRES_PASSWORD=change-me-with-openssl-rand-hex-32

# Pin all production images to immutable release tags or sha256 digests.
POSTGRES_IMAGE=pgvector/pgvector:0.8.2-pg17
CADDY_IMAGE=caddy:2.10.2-alpine
OFELIA_IMAGE=mcuadros/ofelia:0.3.22
HELM_IMAGE=ghcr.io/mindburn-labs/helm-ai-kernel:0.5.0
PILOT_IMAGE=ghcr.io/mindburn-labs/pilot:v1.3.0
WEB_IMAGE=ghcr.io/mindburn-labs/pilot-web:v1.3.0

STORAGE_PROVIDER=local
BACKUP_DIR=/app/backups
BACKUP_CRON_SCHEDULE=0 3 * * *
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_BUCKET=pilot-prod-backups
S3_REGION=fra1
