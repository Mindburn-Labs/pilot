# ─── Pilot Environment Variables ───
# Copy to .env and fill in values.
# See docs/env-reference.md for details.

# ─── Database ───
DATABASE_URL=postgresql://helm:helm@localhost:5432/pilot
# For pg-boss background jobs (uses same DB by default)
# PGBOSS_DATABASE_URL=postgresql://helm:helm@localhost:5432/pilot

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional; defaults to the username returned by getMe for TELEGRAM_BOT_TOKEN.
# Required only when creating managed launch/support bots from the web UI
# before the main Telegram bot has initialized.
# TELEGRAM_MANAGER_BOT_USERNAME=
APP_URL=http://localhost:3100
# Owner chat ID for admin commands (optional, enables owner-gated commands)
# TELEGRAM_OWNER_CHAT_ID=

# ─── Direct LLM Providers (development / non-HELM fallback) ───
# Production deployments keep provider keys on the HELM sidecar, not here.
# Primary direct provider: OpenRouter (multi-model routing)
OPENROUTER_API_KEY=
# Direct providers (optional, for fallback)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Search & Ranking ───
# Cohere Rerank (optional, improves opportunity ranking)
# COHERE_API_KEY=

# ─── Object Storage (S3-compatible) ───
# Leave empty for local filesystem storage
STORAGE_PATH=./data/storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# ─── Connectors (OAuth) ───
# Google (Gmail + Drive connector)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override; defaults to ${APP_URL}/api/connectors/gmail/oauth/callback and /gdrive/oauth/callback
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/connectors/gmail/oauth/callback

# GitHub connector
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Security ───
# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=dev-state-secret-change-me
# Encryption key for tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=dev-encryption-key-change-me
# Trust boundary budget (EUR)
# DAILY_BUDGET_MAX=500
# PER_TASK_BUDGET_MAX=100

# ─── Server ───
PORT=3100
NODE_ENV=development
LOG_LEVEL=info
PYTHON_BIN=./.venv-pipelines/bin/python
PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright
PATCHRIGHT_BROWSERS_PATH=./.cache/ms-patchright

# ─── CORS ───
# Comma-separated list of allowed origins (empty = allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# ─── HELM Governance Sidecar ───
# URL of the HELM governance engine. Pilot routes LLM calls through this
# proxy so Guardian can enforce policy and emit signed receipts.
# In docker-compose this is http://helm:8080; for host dev point at localhost.
HELM_GOVERNANCE_URL=http://localhost:8420
HELM_HEALTH_URL=http://localhost:8421
# When set to 1 every LLM/tool call FAILS CLOSED if HELM is unreachable or denies.
# Set to 0 ONLY in development; production must keep this at 1.
HELM_FAIL_CLOSED=1
# Model name Pilot sends through the HELM proxy.
PILOT_LLM_MODEL=anthropic/claude-sonnet-4
# Upstream LLM endpoint HELM forwards allowed requests to (OpenAI-compatible).
# Leave as OpenRouter default, or point at your provider of choice.
HELM_UPSTREAM_URL=https://openrouter.ai/api/v1
# Ed25519 signing key for evidence packs (generate fresh per deployment).
# Override with a production secret in .env.production. NEVER commit.
EVIDENCE_SIGNING_KEY=pilot-dev-ephemeral-key-change-me
# Pin a published HELM image instead of building from ../../../helm-ai-kernel
# HELM_IMAGE=ghcr.io/mindburn-labs/helm-ai-kernel:0.3.0
# HELM host ports (defaults to 8420 / 8421 to avoid clashing with dev tooling)
HELM_PORT=8420
HELM_HEALTH_PORT=8421
HELM_REGION=pilot-local

# ─── DigitalOcean (production only) ───
# The Droplet compose stack reads these from .env.production.
# See infra/digitalocean/README.md and infra/digitalocean/env.production.example.
# DOMAIN=pilot.example.com
# TLS_EMAIL=ops@example.com
# POSTGRES_PASSWORD=
# HELM_IMAGE=ghcr.io/mindburn-labs/helm-ai-kernel:latest

# ─── Observability (Phase 13 Track D) ───
# Sentry exception capture. Leave blank to disable.
# Get DSN from https://sentry.io/settings/projects/<project>/keys/
# SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry trace export. Leave blank to disable — the GenAI span
# wrappers in packages/shared/src/otel become no-ops. To enable tracing,
# install @opentelemetry/sdk-node + @opentelemetry/exporter-trace-otlp-http
# in your deployment image and set these two:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=pilot
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# Alertmanager (only used by infra/monitoring/alertmanager.yml)
# TELEGRAM_ALERT_CHAT_ID=-1001234567890
# ALERT_EMAIL=ops@mindburn.org
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@mindburn.org
# SMTP_PASS=your-smtp-password
# SMTP_FROM=alerts@mindburn.org

# ─── Langfuse (Phase 14 Track D, optional LLM tracing) ───
# Self-hostable OSS tracing with LLM-specific prompt/output/score/user
# indexing. When all three are set, packages/shared/src/observability/
# langfuse.ts dynamically imports the `langfuse` SDK and shadows each
# agent-loop iteration as a Langfuse generation. Shim is no-op when
# any var is unset. Install `langfuse` in the deployment image to use.
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Braintrust (Phase 14 Track D, optional eval + LLM-as-judge) ───
# Prompt regression suite + rubric scoring. When both are set,
# packages/shared/src/eval/braintrust.ts activates; used by the
# eval-drift.yml CI workflow (future) and the `grade_output` tool.
# BRAINTRUST_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BRAINTRUST_PROJECT=pilot

# ─── MCP consumer (Phase 14 Track A) ─────────────────────────────
# Path to the JSON config mapping server names → McpServerConfig used
# when a subagent's `mcp_servers:` frontmatter declares upstream MCP
# servers. Default: packs/mcp/servers.json (relative to cwd). Absent
# file → empty registry (MCP tools silently disabled).
# MCP_SERVERS_CONFIG_PATH=packs/mcp/servers.json

# ─── MCP provider (Phase 14 Track A) ─────────────────────────────
# Standalone Pilot-as-MCP server, enabled by `docker compose --profile mcp up`.
# MUST be >=16 chars. Refuses to boot anonymously.
# MCP_SERVER_ACCESS_TOKEN=replace-with-a-64-char-random-hex-string
# MCP_SERVER_PORT=3200
# MCP_SERVER_PUBLIC_URL=http://pilot-mcp:3200

# ─── A2A protocol (Phase 15 Track J) ─────────────────────────────
# Required to enable Pilot-as-A2A-server. Missing either var → /a2a returns 503.
# PILOT_A2A_TOKEN=replace-with-64-char-random-hex
# PILOT_A2A_WORKSPACE_ID=<uuid of the workspace incoming A2A tasks dispatch into>
# PILOT_A2A_PUBLIC_URL=https://pilot.example.com
# PILOT_A2A_ORGANIZATION=Your Org
# PILOT_A2A_ORGANIZATION_URL=https://your-org.example.com

# ─── Vision + PDF (Phase 15 Track K) ─────────────────────────────
# analyze_image uses ANTHROPIC_API_KEY (shared with LLM provider — see top).
# parse_pdf requires the pdf-parse peer dep:
#   npm i pdf-parse
# Absent → parse_pdf returns {error:'not_installed'}.

# ─── Ollama self-hosted LLM (Phase 16 Track Q) ───────────────────
# Last-resort LLM provider when no cloud API key is configured. Runs
# locally against http://localhost:11434 (default) or a peer Ollama
# server. No auth (local-trusted host). Works with llama3.1, qwen2.5,
# phi4, mistral, and any other Ollama-served model.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ─── Skills marketplace (Phase 16 Track P) ───────────────────────
# Base URL for the community skills registry. `npm run skills:install -- <name>`
# fetches `<registry>/<name>.tar.gz` + `<registry>/<name>.sha256`, verifies
# the digest, and extracts to ~/.pilot/skills/<name>/.
# PILOT_SKILLS_REGISTRY_URL=https://skills.pilot.dev
